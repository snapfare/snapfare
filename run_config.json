{
  "default_command": "deals-html",
  "default_mode": "full-no-llm",
  "modes": {
    "full-no-llm": {
      "description": "Full run: TravelDealz + Duffel benchmarks, persist to Supabase, no LLM.",
      "persist": true,
      "sources": [
        "travel-dealz"
      ],
      "limit": 100,
      "scrape": {
        "traveldealz": 50,
        "secretflying": 0
      },
      "done_limit": 10000,
      "scraping_overfetch_travel_dealz_min": 100,
      "scraping_overfetch_travel_dealz_max": 500,
      "llm": {
        "action": "off"
      },
      "html": {
        "max_items": 20,
        "display_currency": "CHF",
        "fx_eur_to_chf": 0.93
      },
      "timeout_duffel": 600,
      "duffel": {
        "origins": [
          "ZRH"
        ],
        "months": 6,
        "calls": 10
      }
    },
    "full": {
      "description": "Full run: TravelDealz + Duffel benchmarks, persist to Supabase, with LLM enrichment.",
      "persist": true,
      "sources": [
        "travel-dealz"
      ],
      "limit": 100,
      "scrape": {
        "traveldealz": 50,
        "secretflying": 0
      },
      "done_limit": 10000,
      "scraping_overfetch_travel_dealz_min": 100,
      "scraping_overfetch_travel_dealz_max": 500,
      "llm": {
        "action": "fill",
        "max_items": 50,
        "allow_duffel": true,
        "allucinate": false
      },
      "openai": {
        "min_seconds_between_calls": 3,
        "max_retries": 2,
        "retry_backoff_seconds": 2
      },
      "html": {
        "max_items": 20,
        "display_currency": "CHF",
        "fx_eur_to_chf": 0.93
      },
      "timeout_duffel": 600,
      "duffel": {
        "origins": [
          "ZRH"
        ],
        "months": 6,
        "calls": 10
      }
    },
    "duffel-only": {
      "description": "Duffel benchmark refresh only — 25 searches, no scraping, no LLM. Use: python app.py duffel-refresh --mode duffel-only",
      "persist": true,
      "sources": [],
      "limit": 0,
      "scrape": {
        "traveldealz": 0,
        "secretflying": 0
      },
      "done_limit": 0,
      "llm": {
        "action": "off"
      },
      "html": {
        "max_items": 0
      },
      "timeout_duffel": 600,
      "duffel": {
        "origins": [
          "ZRH"
        ],
        "months": 6,
        "calls": 25
      }
    },
    "smoke_no_llm_1_each": {
      "description": "QA smoke test: 2 TravelDealz articles, 1 Duffel call, no persist, no LLM.",
      "persist": false,
      "sources": [
        "travel-dealz"
      ],
