# ─── Supabase (unified — same project as frontend) ────────────────────────────
SUPABASE_URL=https://wwoowwnjrepokmjgxhlw.supabase.co
SUPABASE_ANON_KEY=<your_supabase_anon_key>
SUPABASE_SERVICE_ROLE_KEY=<your_supabase_service_role_key>

# ─── Duffel (flight price benchmarks — replaces Amadeus) ─────────────────────
DUFFEL_API_KEY=
DUFFEL_ASSUME_BAGGAGE=false

# ─── OpenAI (optional — only needed if llm.action != "off" in run_config.json) ─
OPENAI_API_KEY=
OPENAI_MIN_SECONDS_BETWEEN_CALLS=3

# ─── Unsplash (destination images) ───────────────────────────────────────────
UNSPLASH_ACCESS_KEY=

# ─── Skyscanner affiliate ─────────────────────────────────────────────────────
SKYSCANNER_AFFILIATE_ID=

# ─── Display ──────────────────────────────────────────────────────────────────
DISPLAY_CURRENCY=CHF
FX_EUR_TO_CHF=0.93

# ─── Scraping helpers (optional paid APIs) ────────────────────────────────────
SCRAPINGBEE_API_KEY=
APIFY_API_KEY=
SCRAPERAPI_KEY=
SCRAPINGANT_API_KEY=
